# Server Configuration
NODE_ENV=development
PORT=5000

# Database
# For local MongoDB:
# MONGO_URI=mongodb://localhost:27017/attendance_db

# For MongoDB Atlas (recommended):
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/attendance_db?retryWrites=true&w=majority

# Local offline MongoDB (used when Atlas is unavailable)
MONGO_URI_OFFLINE=mongodb://127.0.0.1:27017/attendance_db

# Force offline mode even when Atlas is reachable
FORCE_OFFLINE=false

# Auto-sync interval in minutes (local-to-cloud sync)
SYNC_INTERVAL_MINUTES=5

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production-minimum-32-characters
JWT_EXPIRE=7d

# Frontend URL (for CORS configuration)
# Development:
FRONTEND_URL=http://localhost:3001

# Production (after deploying to Vercel):
# FRONTEND_URL=https://your-app.vercel.app

# API Version
API_VERSION=v1

# Face Recognition
# Euclidean distance threshold for duplicate-face detection (0.0–1.0).
# Lower = stricter (fewer false "face already used" errors).
# Recommended: 0.4 (default). Use 0.5 if faces are hard to enroll.
FACE_DUPLICATE_THRESHOLD=0.4

# SMS Configuration (PhilSMS)
# Get your API key from https://philsms.com/
PHILSMS_API_KEY=your_philsms_api_key_here
PHILSMS_SENDER_ID=FacePass

# INSTRUCTIONS FOR DEPLOYMENT:
# 1. Copy this file to .env
# 2. Update MONGO_URI with your MongoDB Atlas connection string
# 3. Generate a strong JWT_SECRET (minimum 32 random characters)
# 4. Add your PhilSMS API key and sender ID
# 5. After deploying frontend to Vercel, update FRONTEND_URL
# 6. Set NODE_ENV=production for production deployment
# 7. Add all these variables to Render environment variables (do not include comments)
